10 REM Number Guessing Game
20 PRINT "GUESS THE NUMBER (1-100)"
30 LET S = INT(RND(1)*100)+1
40 LET G = 0
50 INPUT "YOUR GUESS? ";N
60 LET G = G + 1
70 IF N = S THEN GOTO 110
80 IF N < S THEN PRINT "TOO LOW!"
90 IF N > S THEN PRINT "TOO HIGH!"
100 GOTO 50
110 PRINT "CORRECT! YOU GOT IT IN";G;"GUESSES!"
120 END
