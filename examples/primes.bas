10 REM Prime numbers using sieve
20 DIM P(100)
30 FOR I = 2 TO 100
40   P(I) = 1
50 NEXT I
60 FOR I = 2 TO 10
70   IF P(I) = 0 THEN GOTO 110
80   FOR J = I*2 TO 100 STEP I
90     P(J) = 0
100  NEXT J
110 NEXT I
120 PRINT "PRIMES UP TO 100:"
130 FOR I = 2 TO 100
140   IF P(I) = 1 THEN PRINT I;
150 NEXT I
160 PRINT
170 END
