10 REM DATA / READ / RESTORE demo
20 DATA 10, 20, 30, 40, 50
30 DATA "APPLE", "BANANA", "CHERRY"
40 PRINT "NUMBERS:"
50 FOR I = 1 TO 5
60   READ N
70   PRINT N;
80 NEXT I
90 PRINT
100 PRINT "FRUITS:"
110 FOR I = 1 TO 3
120   READ F$
130   PRINT F$
140 NEXT I
150 RESTORE
160 PRINT "AFTER RESTORE:"
170 READ N
180 PRINT "FIRST NUMBER AGAIN:";N
190 END
