10  REM BUBBLE SORT DEMO - 200 NUMBERS
20  DIM N(200)
30  PRINT CHR$(147)
40  PRINT "GENERATING 200 RANDOM NUMBERS..."
50  FOR I=1 TO 200
60    N(I)=INT(RND(1)*1000)+1
70  NEXT I
80  PRINT "DONE. NOW START TO SORT..."
90  REM GET A$ : IF A$="" THEN GOTO 90
100 PRINT "SORTING 200 NUMBERS - PLEASE WAIT..."
110 FOR P=1 TO 199
120   FOR I=1 TO 200-P
130     IF N(I)<=N(I+1) THEN GOTO 160
140     T=N(I) : N(I)=N(I+1) : N(I+1)=T
160   NEXT I
170 NEXT P
180 PRINT "SORTED! NOW SEE RESULTS..."
190 REM GET A$ : IF A$="" THEN GOTO 190
200 PRINT CHR$(147)
210 PRINT "SORTED LIST (1-200):"
220 PRINT
230 FOR I=1 TO 200
240   PRINT N(I);
250   REM PAUSE EVERY 40 NUMBERS SO SCREEN DOESNT SCROLL TOO FAST
270 NEXT I
280 PRINT
290 PRINT "DONE! MIN=";N(1);" MAX=";N(200)
300 END
